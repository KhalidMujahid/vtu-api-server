# Server Configuration
SERVER_URL=http://localhost:5000

# VTU Provider Configuration
# Add your API keys and URLs here

# Default VTU Provider
DEFAULT_VTU_PROVIDER=clubkonnect

# Club Konnect (NelloBytes) - Primary Provider
# Uses existing NelloBytes API
VTU_BASE_URL=https://www.nellobytesystems.com
NELLO_USER_ID=your_nello_user_id
NELLO_API_KEY=your_nello_api_key

# Airtime Nigeria
AIRTIME_NIGERIA_BASE_URL=https://www.airtimenigeria.com/api/v1
AIRTIME_NIGERIA_API_KEY=your_airtime_nigeria_api_key

# SMEPlug
SMEPLUG_BASE_URL=https://smeplug.ng/api/v1
SMEPLUG_API_KEY=your_smeplug_secret_key

# Pluginng
PLUGINNG_BASE_URL=https://pluginng.com
PLUGINNG_EMAIL=your_pluginng_email
PLUGINNG_PASSWORD=your_pluginng_password
# Optional: use a pre-generated bearer token instead of email/password login
PLUGINNG_TOKEN=

# AlrahuzData
ALRAHUZDATA_BASE_URL=https://alrahuzdata.com.ng
# API token without the "Token " prefix
ALRAHUZDATA_TOKEN=your_alrahuzdata_token
# Optional request timeout (milliseconds)
ALRAHUZDATA_TIMEOUT_MS=45000
# Background reconciliation for pending Alrahuz data transactions
ALRAHUZ_RECON_ENABLED=true
# 2 minutes
ALRAHUZ_RECON_INTERVAL_MS=120000
# Max pending records to process per cycle
ALRAHUZ_RECON_LIMIT=50
