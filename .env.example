# Server Configuration
SERVER_URL=http://localhost:5000

# VTU Provider Configuration
# Add your API keys and URLs here

# Default VTU Provider
DEFAULT_VTU_PROVIDER=clubkonnect

# Club Konnect (NelloBytes) - Primary Provider
# Uses existing NelloBytes API
VTU_BASE_URL=https://www.nellobytesystems.com
NELLO_USER_ID=your_nello_user_id
NELLO_API_KEY=your_nello_api_key

# Airtime Nigeria
AIRTIME_NIGERIA_BASE_URL=https://www.airtimenigeria.com/api/v1
AIRTIME_NIGERIA_API_KEY=your_airtime_nigeria_api_key

# SMEPlug
SMEPLUG_BASE_URL=https://smeplug.ng/api/v1
SMEPLUG_API_KEY=your_smeplug_secret_key
