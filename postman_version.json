{
  "info": {
    "_postman_id": "yareema-data-hub-postman-version",
    "name": "Yareema Data Hub - Gift Cards, International Airtime, EPIN",
    "description": "Slim Postman collection for gift cards, international airtime, and Databundle Recharge PIN endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "giftcard_country_code",
      "value": "US",
      "type": "string"
    },
    {
      "key": "giftcard_product_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "giftcard_amount",
      "value": "25",
      "type": "string"
    },
    {
      "key": "giftcard_transaction_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "country_code",
      "value": "US",
      "type": "string"
    },
    {
      "key": "operator_id",
      "value": "12345",
      "type": "string"
    },
    {
      "key": "recipient_number",
      "value": "5551234567",
      "type": "string"
    },
    {
      "key": "airtime_amount",
      "value": "5",
      "type": "string"
    },
    {
      "key": "airtime_amount_ngn",
      "value": "8000",
      "type": "string"
    },
    {
      "key": "sender_number",
      "value": "5550000000",
      "type": "string"
    },
    {
      "key": "epin_plan_id",
      "value": "1000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Gift Cards",
      "item": [
        {
          "name": "Browse Gifts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/giftcards/catalog",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "giftcards",
                "catalog"
              ]
            }
          }
        },
        {
          "name": "Browse Gifts Refresh",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/giftcards/catalog?refresh=true",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "giftcards",
                "catalog"
              ],
              "query": [
                {
                  "key": "refresh",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Browse Gifts by Country",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/giftcards/catalog?countryCode={{giftcard_country_code}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "giftcards",
                "catalog"
              ],
              "query": [
                {
                  "key": "countryCode",
                  "value": "{{giftcard_country_code}}"
                }
              ]
            }
          }
        },
        {
          "name": "Choose Gift",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/giftcards/catalog/{{giftcard_product_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "giftcards",
                "catalog",
                "{{giftcard_product_id}}"
              ]
            }
          }
        },
        {
          "name": "Preview Gift Price",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{giftcard_product_id}}\",\n  \"amount\": {{giftcard_amount}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/giftcards/quote",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "giftcards",
                "quote"
              ]
            }
          }
        },
        {
          "name": "Buy Gift",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"reloadly:amazon-us\",\n  \"amount\": 25,\n  \"recipientEmail\": \"recipient@example.com\",\n  \"recipientName\": \"Recipient Name\",\n  \"senderName\": \"Sender Name\",\n  \"message\": \"Happy gifting!\",\n  \"transactionPin\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/giftcards/buy",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "giftcards",
                "buy"
              ]
            }
          }
        },
        {
          "name": "View Code",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/giftcards/orders/{{giftcard_transaction_id}}/code",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "giftcards",
                "orders",
                "{{giftcard_transaction_id}}",
                "code"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Send Airtime",
      "item": [
        {
          "name": "Browse Countries",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/international/countries",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "international",
                "countries"
              ]
            }
          }
        },
        {
          "name": "Choose Operator",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/international/operators/{{country_code}}?page=1&size=100&includeBundles=true",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "international",
                "operators",
                "{{country_code}}"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "size",
                  "value": "100"
                },
                {
                  "key": "includeBundles",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Preview Top Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operatorId\": {{operator_id}},\n  \"amount\": {{airtime_amount}},\n  \"useLocalAmount\": false,\n  \"recipientCountryCode\": \"NG\",\n  \"recipientNumber\": \"{{recipient_number}}\",\n  \"senderCountryCode\": \"NG\",\n  \"senderNumber\": \"{{sender_number}}\",\n  \"amountNgn\": {{airtime_amount_ngn}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/international/quote",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "international",
                "quote"
              ]
            }
          }
        },
        {
          "name": "Send Top Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operatorId\": {{operator_id}},\n  \"amount\": 5,\n  \"useLocalAmount\": false,\n  \"recipientCountryCode\": \"NG\",\n  \"recipientNumber\": \"{{recipient_number}}\",\n  \"senderCountryCode\": \"NG\",\n  \"senderNumber\": \"{{sender_number}}\",\n  \"amountNgn\": 8000,\n  \"transactionPin\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/international/topup",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "international",
                "topup"
              ]
            }
          }
        },
        {
          "name": "View Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/international/transactions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "international",
                "transactions"
              ]
            }
          }
        },
        {
          "name": "View Transaction",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/international/transactions/{{giftcard_transaction_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "international",
                "transactions",
                "{{giftcard_transaction_id}}"
              ]
            }
          }
        },
        {
          "name": "Check Balance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/international/balance",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "international",
                "balance"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Recharge PIN",
      "item": [
        {
          "name": "Browse EPIN Plans",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/epin/plans",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "epin",
                "plans"
              ]
            }
          }
        },
        {
          "name": "Browse Recharge PIN Plans",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/recharge-pin/plans",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "recharge-pin",
                "plans"
              ]
            }
          }
        },
        {
          "name": "Buy EPIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"network\": \"mtn\",\n  \"dataPlan\": \"{{epin_plan_id}}\",\n  \"quantity\": 1,\n  \"transactionPin\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/epin/purchase",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "epin",
                "purchase"
              ]
            }
          }
        },
        {
          "name": "Buy Recharge PIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"network\": \"mtn\",\n  \"dataPlan\": \"{{epin_plan_id}}\",\n  \"quantity\": 1,\n  \"transactionPin\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/telecom/recharge-pin/purchase",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "telecom",
                "recharge-pin",
                "purchase"
              ]
            }
          }
        }
      ]
    }
  ]
}
